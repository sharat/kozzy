{
  "name": "kozzy",
  "version": "2.0.0",
  "description": "Pretty formatter for ktlint output - compact and stylish",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "author": {
    "name": "Sarath C",
    "url": "https://sarat.io/"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin/cmd.ts --format esm,cjs --dts --out-dir dist --clean",
    "prepublishOnly": "npm run build && npm test",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "kozzy": "dist/bin/cmd.cjs"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "text-table": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/text-table": "^0.2.5",
    "@vitest/coverage-v8": "^4.1.5",
    "oxlint": "^1.61.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharat/kozzy.git"
  },
  "bugs": {
    "url": "https://github.com/sharat/kozzy/issues"
  },
  "keywords": [
    "ktlint",
    "kotlin",
    "linter",
    "formatter",
    "pretty",
    "pretty output",
    "kozzy",
    "stylish",
    "stylish formatter",
    "stylish reporter"
  ]
}
